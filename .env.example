# Required environment variables for CVMaker

# SQLite database URL (relative path inside container)
DATABASE_URL=sqlite+aiosqlite:///./cvmaker.db

# Path where uploaded/stored files are saved
STORAGE_PATH=./assets/storage

# Path where built PDFs are saved
OUTPUT_PATH=./assets/outputs

# Path where LaTeX .tex template files are discovered
TEMPLATES_PATH=./assets/templates
